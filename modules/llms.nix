              import { env } from "cloudflare:test";
              import { describe, it, expect } from "vitest";

              describe("MyDO", () => {
                it("should work", async () => {
                  const stub = env.MY_DO.getByName("test");
                  const result = await stub.addItem("test");
                  expect(result).toBe(1);
                });
              });
              ```

